# Data files are excluded from git — see README for how to obtain them.

# Processed pipelines only — raw downloads in data/raw/ are committed (large files use Git LFS)
data/interim/*
!data/interim/.gitkeep

data/processed/*
!data/processed/.gitkeep

# Stray exports outside data/raw (keep repo clean)
*.parquet

